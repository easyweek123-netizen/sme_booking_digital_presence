# Server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
FRONTEND_APP_URL=http://localhost:5173

# Database
DB_TYPE=postgres                       # 'postgres' | 'mysql'
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=bookeasy
DB_SSL=false                           # set 'true' in production

# Auth
ADMIN_SECRET=change-me-in-production
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
GOOGLE_APPLICATION_CREDENTIALS=../path-to-firebase-service-account.json
# Or in production:
# FIREBASE_SERVICE_ACCOUNT={...JSON-stringified...}

# Email (Resend)
RESEND_API_KEY=re_replace_me
EMAIL_FROM=BookEasy <onboarding@resend.dev>
ADMIN_EMAIL=admin@example.com

# AI
AI_API_KEY=sk-replace-me
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Billing
BILLING_MODE=mock                      # 'mock' | 'stripe'
MOCK_WEBHOOK_SECRET=dev-mock-secret    # Used by mock provider for signature verification utilities / tests (no HTTP webhook)
# Stripe webhook URL (Dashboard): https://<your-host>/api/billing/webhook/stripe
# STRIPE_SECRET_KEY=sk_test_replace_me
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
# STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
